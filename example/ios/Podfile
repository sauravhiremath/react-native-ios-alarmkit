# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'AlarmKitExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
      end
    end

    # fmt 11.0.2 (used by RN 0.83.x) is incompatible with Xcode 26.4 / Apple Clang 22+
    # which is stricter about consteval evaluation. Disabling FMT_USE_CONSTEVAL is the
    # most popular fix until RN 0.84+ (which resolves this via precompiled binaries).
    # Tracking: https://github.com/facebook/react-native/issues/55601
    fmt_base_h = "#{installer.sandbox.root}/fmt/include/fmt/base.h"
    if File.exist?(fmt_base_h)
      File.chmod(0644, fmt_base_h)
      content = File.read(fmt_base_h)
      File.write(fmt_base_h, content.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0'))
    end

    # Inject local.xcconfig (gitignored) into Pods xcconfigs so DEVELOPMENT_TEAM
    # can be set locally without committing it. Copy local.xcconfig.sample → local.xcconfig.
    ['debug', 'release'].each do |config_name|
      xcconfig_path = "#{installer.sandbox.root}/Target Support Files/Pods-AlarmKitExample/Pods-AlarmKitExample.#{config_name}.xcconfig"
      next unless File.exist?(xcconfig_path)
      content = File.read(xcconfig_path)
      include_line = '#include? "../../../local.xcconfig"'
      next if content.include?(include_line)
      File.write(xcconfig_path, "#{include_line}\n#{content}")
    end
  end
end
